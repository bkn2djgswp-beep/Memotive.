<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Memotive</title>
    <style>
        /* 🎨 전체 화면 및 기본 레이아웃 스타일 */
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Apple SD Gothic Neo', sans-serif; }
        body { background-color: #f5f7fa; color: #333; display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 20px; }
        .container { background: white; width: 100%; max-width: 450px; padding: 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
        h1, h2, h3 { text-align: center; margin-bottom: 20px; color: #4a5568; }
        
        /* 🔐 로그인 / 회원가입 화면 스타일 */
        #login-screen { display: block; }
        .input-group { margin-bottom: 15px; }
        .input-group label { display: block; margin-bottom: 5px; font-weight: bold; color: #718096; }
        input[type="text"], input[type="password"] { width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 10px; font-size: 16px; }
        button { width: 100%; padding: 12px; border: none; background-color: #4f46e5; color: white; border-radius: 10px; font-size: 16px; font-weight: bold; cursor: pointer; transition: background 0.2s; }
        button:hover { background-color: #4338ca; }
        .switch-auth { text-align: center; margin-top: 15px; color: #4f46e5; cursor: pointer; text-decoration: underline; font-size: 14px; }

        /* 🏠 메인 웹사이트 화면 스타일 (로그인 성공 전까지는 숨겨짐) */
        #main-screen { display: none; }
        .profile-box { background: #eeebff; padding: 20px; border-radius: 15px; margin-bottom: 25px; position: relative; }
        .profile-goal { font-size: 16px; font-weight: bold; color: #4f46e5; margin-top: 5px; }
        .edit-btn { position: absolute; top: 15px; right: 15px; background: #dbd5ff; color: #4f46e5; padding: 5px 10px; font-size: 12px; border-radius: 5px; width: auto; }
        
        /* 🧪 동글동글한 귀여운 Memory Cells 입력창 및 세포 스타일 */
        .memory-input-box { display: flex; gap: 10px; margin-bottom: 20px; }
        .memory-input-box input { flex: 1; padding: 10px; border: 1px solid #e2e8f0; border-radius: 8px; }
        .memory-input-box button { width: auto; padding: 10px 20px; }
        
        .memory-list { list-style: none; display: flex; flex-wrap: wrap; gap: 12px; margin-top: 15px; }
        .memory-item { background: #e0e7ff; color: #4338ca; padding: 12px 20px; border-radius: 30px; font-weight: 500; cursor: pointer; transition: transform 0.2s, background 0.2s; box-shadow: 0 4px 6px rgba(0,0,0,0.05); display: flex; align-items: center; gap: 10px; }
        .memory-item:hover { transform: scale(1.05); background: #c7d2fe; }
        
        .delete-btn { background: #fee2e2; color: #ef4444; border: none; padding: 2px 8px; font-size: 11px; border-radius: 50px; cursor: pointer; font-weight: bold; }
        .delete-btn:hover { background: #fca5a5; }
        
        /* 🚨 화면 정중앙 팝업창(모달) 스타일 */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.4); z-index: 1000; justify-content: center; align-items: center; }
        .modal-box { background: white; padding: 30px; border-radius: 20px; width: 85%; max-width: 380px; text-align: center; box-shadow: 0 15px 40px rgba(0,0,0,0.15); animation: popUp 0.3s ease; }
        .modal-content { font-size: 18px; font-weight: bold; color: #1e1b4b; line-height: 1.5; margin-bottom: 25px; word-break: break-all; }
        .modal-close-btn { background-color: #4f46e5; color: white; width: 100%; padding: 12px; border-radius: 10px; font-size: 15px; font-weight: bold; }
        
        @keyframes popUp {
            from { transform: scale(0.8); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }

        .logout-btn { background-color: #94a3b8; margin-top: 30px; }
        .logout-btn:hover { background-color: #64748b; }
    </style>
</head>
<body>

    <div class="container">
        <div id="login-screen">
            <h1 id="auth-title">Memotive 로그인</h1>
            <div class="input-group">
                <label for="username">아이디</label>
                <input type="text" id="username" placeholder="아이디를 입력하세요">
            </div>
            <div class="input-group">
                <label for="password">비밀번호</label>
                <input type="password" id="password" placeholder="비밀번호를 입력하세요">
            </div>
            <button id="auth-btn" onclick="handleAuth()">로그인하기</button>
            <p class="switch-auth" id="switch-auth-text" onclick="toggleAuthMode()">계정이 없으신가요? 회원가입하기</p>
        </div>

        <div id="main-screen">
            <div class="profile-box">
                <h2>나의 프로필</h2>
                <p>현재 목표:</p>
                <p class="profile-goal" id="goal-text">목표를 설정해 주세요!</p>
                <button class="edit-btn" onclick="editGoal()">수정</button>
            </div>

            <h3>🧪 Memory Cells</h3>
            <div class="memory-input-box">
                <input type="text" id="memory-input" placeholder="오늘의 기억 세포를 추가하세요">
                <button onclick="addMemory()">추가</button>
            </div>

            <ul class="memory-list" id="memory-list-container">
                </ul>

            <button class="logout-btn" onclick="logout()">로그아웃</button>
        </div>
    </div>

    <div class="modal-overlay" id="memory-modal" onclick="closeModal(event)">
        <div class="modal-box" onclick="event.stopPropagation()">
            <h3 style="color: #4f46e5; font-size: 15px; margin-bottom: 10px;">🧬 세포 기억 내용</h3>
            <p class="modal-content" id="modal-text">선택된 내용이 없습니다.</p>
            <button class="modal-close-btn" onclick="document.getElementById('memory-modal').style.display = 'none'">확인</button>
        </div>
    </div>

    <script>
        let isSignUpMode = false;

        // 브라우저가 켜질 때 자동 로그인 체크
        window.onload = function() {
            const loggedInUser = localStorage.getItem('loggedInUser');
            if (loggedInUser) {
                showMainScreen();
            }
        };

        function showMainScreen() {
            document.getElementById('login-screen').style.display = 'none';
            document.getElementById('main-screen').style.display = 'block';
            loadProfileGoal();
            renderMemories();
        }

        // 로그인 <-> 회원가입 모드 전환
        function toggleAuthMode() {
            isSignUpMode = !isSignUpMode;
            const title = document.getElementById('auth-title');
            const btn = document.getElementById('auth-btn');
            const switchText = document.getElementById('switch-auth-text');

            if (isSignUpMode) {
                title.innerText = "Memotive 회원가입";
                btn.innerText = "가입하기";
                switchText.innerText = "이미 계정이 있으신가요? 로그인하기";
            } else {
                title.innerText = "Memotive 로그인";
                btn.innerText = "로그인하기";
                switchText.innerText = "계정이 없으신가요? 회원가입하기";
            }
        }

        // 회원가입 및 로그인 처리 기능
        function handleAuth() {
            const id = document.getElementById('username').value.trim();
            const pw = document.getElementById('password').value.trim();

            if (!id || !pw) {
                alert('아이디와 비밀번호를 모두 입력해주세요!');
                return;
            }

            if (isSignUpMode) {
                if (localStorage.getItem(`user_${id}`)) {
                    alert('이미 존재하는 아이디입니다.');
                } else {
                    localStorage.setItem(`user_${id}`, pw);
                    alert('회원가입 완료! 로그인 해주세요.');
                    toggleAuthMode();
                }
            } else {
                const savedPw = localStorage.getItem(`user_${id}`);
                if (savedPw && savedPw === pw) {
                    localStorage.setItem('loggedInUser', id);
                    showMainScreen();
                } else {
                    alert('아이디 또는 비밀번호가 틀렸습니다.');
                }
            }
        }

        function logout() {
            localStorage.removeItem('loggedInUser');
            document.getElementById('login-screen').style.display = 'block';
            document.getElementById('main-screen').style.display = 'none';
            document.getElementById('username').value = '';
            document.getElementById('password').value = '';
        }

        // 목표 수정 및 불러오기 기능
        function loadProfileGoal() {
            const id = localStorage.getItem('loggedInUser');
            const savedGoal = localStorage.getItem(`goal_${id}`);
            document.getElementById('goal-text').innerText = savedGoal ? savedGoal : "목표를 설정해 주세요!";
        }

        function editGoal() {
            const id = localStorage.getItem('loggedInUser');
            const currentGoal = document.getElementById('goal-text').innerText;
            const newGoal = prompt('새로운 목표를 입력하세요:', currentGoal);
            
            if (newGoal !== null && newGoal.trim() !== '') {
                localStorage.setItem(`goal_${id}`, newGoal.trim());
                loadProfileGoal();
            }
        }

        // 세포 기억 리스트 데이터 제어
        function getMemories() {
            const id = localStorage.getItem('loggedInUser');
            const memories = localStorage.getItem(`memories_${id}`);
            return memories ? JSON.parse(memories) : [];
        }

        function renderMemories() {
            const container = document.getElementById('memory-list-container');
            container.innerHTML = '';
            const memories = getMemories();

            memories.forEach((memory, index) => {
                const li = document.createElement('li');
                li.className = 'memory-item';
                // 세포 터치 시 중앙 팝업 함수 실행
                li.setAttribute('onclick', `openMemoryModal('${memory.replace(/'/g, "\\'")}')`);
                
                const shortText = memory.length > 10 ? memory.substring(0, 10) + '...' : memory;
                
                li.innerHTML = `
                    <span>🔮 ${shortText}</span>
                    <button class="delete-btn" onclick="deleteMemory(event, ${index})">삭제</button>
                `;
                container.appendChild(li);
            });
        }

        function addMemory() {
            const id = localStorage.getItem('loggedInUser');
            const input = document.getElementById('memory-input');
            const text = input.value.trim();

            if (!text) return;

            const memories = getMemories();
            memories.push(text);
            localStorage.setItem(`memories_${id}`, JSON.stringify(memories));
            
            input.value = '';
            renderMemories();
        }

        function deleteMemory(event, index) {
            event.stopPropagation(); // 세포 터치 팝업 이벤트 방지
            const id = localStorage.getItem('loggedInUser');
            const memories = getMemories();
            if (confirm('이 세포 기억을 완전히 삭제하시겠습니까?')) {
                memories.splice(index, 1);
                localStorage.setItem(`memories_${id}`, JSON.stringify(memories));
                renderMemories();
            }
        }

        // 세포 한 번 터치했을 때 중앙 팝업창을 여는 함수
        function openMemoryModal(text) {
            document.getElementById('modal-text').innerText = text;
            document.getElementById('memory-modal').style.display = 'flex';
        }

        function closeModal(event) {
            if(event.target === document.getElementById('memory-modal')) {
                document.getElementById('memory-modal').style.display = 'none';
            }
        }
    </script>
</body>
</html>
